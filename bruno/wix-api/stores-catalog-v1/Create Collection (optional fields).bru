meta {
  name: Create Collection (optional fields)
  type: http
  seq: 9
}

post {
  url: {{wixStoresV1BaseUrl}}/collections
  body: json
  auth: none
}

body:json {
  {
    "collection": {
      "name": "{{newCollectionName}}",
      "description": "{{newCollectionDescription}}",
      "slug": "{{newCollectionSlug}}",
      "visible": true
    }
  }
}

headers {
  Authorization: {{wixApiKey}}
  Accept: application/json
}
