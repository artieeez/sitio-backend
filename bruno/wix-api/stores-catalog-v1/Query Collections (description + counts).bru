meta {
  name: Query Collections (description + counts)
  type: http
  seq: 5
}

post {
  url: {{wixStoresReaderBaseUrl}}/collections/query
  body: json
  auth: none
}

body:json {
  {
    "query": {},
    "includeDescription": true,
    "includeNumberOfProducts": true
  }
}

headers {
  Authorization: {{wixApiKey}}
  Accept: application/json
}
