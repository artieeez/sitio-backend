meta {
  name: Create Collection (minimal)
  type: http
  seq: 8
}

post {
  url: {{wixStoresV1BaseUrl}}/collections
  body: json
  auth: none
}

body:json {
  {
    "collection": {
      "name": "{{newCollectionName}}"
    }
  }
}

headers {
  Authorization: {{wixApiKey}}
  Accept: application/json
}
