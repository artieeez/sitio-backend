meta {
  name: Get Product (with wix-site-id)
  type: http
  seq: 3
}

get {
  url: {{wixStoresReaderBaseUrl}}/products/{{productId}}
  body: none
  auth: none
}

params:query {
  includeMerchantSpecificData: false
}

headers {
  Authorization: {{wixApiKey}}
  Accept: application/json
  wix-site-id: {{wixSiteId}}
}
