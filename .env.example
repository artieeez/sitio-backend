# PostgreSQL connection (local dev: localhost:5432). Used by Prisma after schema is added.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/sitio_dev"

# Comma-separated browser origins allowed to call the API (CORS). If unset in development,
# all origins are reflected (safe for local use). In production, set this to your dashboard URL(s).
# CORS_ORIGINS=http://localhost:5173,https://dashboard.example.com
